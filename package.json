{
  "name": "@mahitoburrito/openui-desktop",
  "version": "1.0.9",
  "description": "AI Agent Command Center — Desktop App",
  "main": "dist/electron/electron/main.js",
  "author": "mahitoburrito <mahitraj@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mahitoburrito/openui-desktop.git"
  },
  "homepage": "https://github.com/mahitoburrito/openui-desktop#readme",
  "keywords": [
    "ai",
    "coding-agent",
    "claude-code",
    "openui",
    "desktop",
    "electron",
    "terminal",
    "canvas"
  ],
  "bin": {
    "openui-desktop": "./bin/openui-desktop"
  },
  "files": [
    "bin/",
    "server/",
    "client/dist/",
    "claude-code-plugin/",
    "dist/",
    "tsconfig.electron.json",
    "README.md"
  ],
  "scripts": {
    "dev": "VITE_PORT=5173 SERVER_PORT=6968 concurrently \"npm run dev:client\" \"npm run dev:electron\"",
    "dev:client": "cd client && SERVER_PORT=${SERVER_PORT:-6968} npx vite --port ${VITE_PORT:-5173} --strictPort",
    "dev:electron": "tsc -p tsconfig.electron.json && VITE_PORT=${VITE_PORT:-5173} PORT=${SERVER_PORT:-6968} electron .",
    "build:client": "cd client && npx vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:client && npm run build:electron",
    "start": "node bin/openui-desktop.js",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "prepublishOnly": "npm run build",
    "postinstall": "cd client && npm install"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@prbe.ai/electron-sdk": "^0.1.18",
    "electron-updater": "^6.8.3",
    "hono": "^4.7.5",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/ws": "^8.5.14",
    "concurrently": "^9.1.2",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.3"
  },
  "build": {
    "appId": "com.openui.desktop",
    "productName": "OpenUI",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "client/dist/**/*",
      "claude-code-plugin/**/*",
      "resources/**/*"
    ],
    "icon": "resources/icon",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "resources/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "resources/icon.png"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "resources/icon.ico"
    },
    "extraResources": [
      {
        "from": "claude-code-plugin",
        "to": "claude-code-plugin"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "mahitoburrito",
      "repo": "openui-desktop"
    }
  }
}
